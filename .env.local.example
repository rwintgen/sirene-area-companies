# ─────────────────────────────────────────────────────────────────
# Local development — copy to .env.local and fill in values
# ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (via Cloud SQL Auth Proxy running locally)
# Start proxy with:
#   cloud-sql-proxy project-95adcfa2-64d3-4f79-be3:europe-west4:public-data-maps-db
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/sirene_db

# ─────────────────────────────────────────────────────────────────
# Stripe — https://dashboard.stripe.com/apikeys
# Price IDs start with price_... (not prod_...)
# ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_INDIVIDUAL_MONTHLY=price_...
STRIPE_PRICE_INDIVIDUAL_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...

# ─────────────────────────────────────────────────────────────────
# Production (Firebase App Hosting) — set these in the console:
#   Firebase Console → App Hosting → your backend → Environment variables
# ─────────────────────────────────────────────────────────────────

# CLOUD_SQL_CONNECTION_NAME=project-95adcfa2-64d3-4f79-be3:europe-west4:public-data-maps-db
# DB_USER=postgres
# DB_NAME=sirene_db

# ─────────────────────────────────────────────────────────────────
# Vertex AI — AI company overview feature
# Requires Vertex AI API enabled and IAM role granted (see README)
# ─────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=europe-west4
# GEMINI_MODEL=gemini-2.0-flash  (optional, this is the default)
